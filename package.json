{
  "name": "openhelm",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "./start-openhelm.sh",
    "tiles": "martin --config martin-config.yaml",
    "stop": "sudo systemctl stop openhelm-backend 2>/dev/null; pkill -f 'martin|vite|chromium-browser' || true",
    "dev:restart": "./start-dev.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@canboat/canboatjs": "^3.14.0",
    "@heroicons/react": "^2.2.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "check-disk-space": "^3.4.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.2.5",
    "grib2-simple": "^1.1.1",
    "maplibre-gl": "^4.5.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.11.0",
    "serialport": "^13.0.0",
    "sqlite3": "^5.1.7",
    "three": "^0.182.0",
    "winston": "^3.17.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "terser": "^5.46.0",
    "vite": "^5.2.0",
    "vitest": "^4.1.2"
  }
}
